@page "/createplan"
@using AppForSEII2526.Maui.Resources.Languages
@inject IStringLocalizer<Shared> Localizer

<div class="create-plan-container">
    <h2 class="create-plan-title">@Localizer["CreatePlan"] - @Localizer["SelectClasses"]</h2>
    <p class="create-plan-subtext">
        @Localizer["SelectClassesDescription"]
    </p>

    <div class="filters-container">
        <button class="show-filters-btn" @onclick="ToggleFilters">
            @(showFilters? Localizer["HideFilters"] : Localizer["ShowFilters"])
        </button>

        @if (showFilters)
        {
            <div class="filters-content">
                <div class="filter-group">
                    <label>@Localizer["FilterByType"]</label>
                    <select>
                        <option>@Localizer["AllTypes"]</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label>@Localizer["FilterByDay"]</label>
                    <select>
                        <option>@Localizer["AllDays"]</option>
                    </select>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private bool showFilters = false;

    private void ToggleFilters()
    {
        showFilters = !showFilters;
    }
}