@page "/settings"
@using AppForSEII2526.Maui.Resources.Languages
@inject IStringLocalizer<Shared> Localizer
@using System.Globalization
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div class="settings-container">
    <h2>@Localizer["Settings"]</h2>

    <!-- Language Configuration -->
    <div class="setting-group">
        <h3>@Localizer["Language"]</h3>
        <select @onchange="ChangeLanguage" class="lang-select" value="@currentLang">
            <option value="en"><img src="/images/flags/en.png" /> English</option>
            <option value="es" class="flag-es">Español</option>
            <option value="fr" class="flag-fr">Français</option>
            <option value="ja" class="flag-ja">日本語</option>
        </select>
        <p class="setting-description">@Localizer["LanguageDescription"]</p>
    </div>

    <!-- Theme Configuration -->
    <div class="setting-group">
        <h3>@Localizer["Theme"]</h3>
        <select @onchange="ChangeTheme" class="theme-select" value="@currentTheme">
            <option value="light">@Localizer["LightTheme"]</option>
            <option value="dark">@Localizer["DarkTheme"]</option>
            <!-- Color blind Themes -->
            <option value="protanopia">@Localizer["ProtanopiaTheme"]</option>
            <option value="deuteranopia">@Localizer["DeuteranopiaTheme"]</option>
            <option value="tritanopia">@Localizer["TritanopiaTheme"]</option>
        </select>
        <p class="setting-description">@Localizer["ThemeDescription"]</p>
    </div>

    <!-- Font Size Configuration -->
    <div class="setting-group">
        <h3>@Localizer["FontSize"]</h3>
        <select @onchange="ChangeFontSize" class="font-size-select" value="@currentFontSize">
            <option value="small">@Localizer["Small"]</option>
            <option value="default">@Localizer["Default"]</option>
            <option value="large">@Localizer["Large"]</option>
        </select>
        <p class="setting-description">@Localizer["FontSizeDescription"]</p>
    </div>

</div>

@code {
    private string currentLang = "en";
    private string currentTheme = "light";
    private string currentFontSize = "default";

    protected override async Task OnInitializedAsync()
    {
        // Cargar configuración
        var saved = await SecureStorage.Default.GetAsync("AppCulture");
        currentLang = saved ?? "en";

        var themeSaved = await SecureStorage.Default.GetAsync("AppTheme");
        currentTheme = themeSaved ?? "light";

        var fontSizeSaved = await SecureStorage.Default.GetAsync("AppFontSize");
        currentFontSize = fontSizeSaved ?? "default";
        await ApplyFontSize();

        StateHasChanged();
    }

    private async Task ChangeLanguage(ChangeEventArgs e)
    {
        var selectedLang = e.Value?.ToString() ?? "en";

        if (selectedLang != currentLang && (selectedLang == "en" || selectedLang == "es" || selectedLang == "fr" || selectedLang == "ja"))
        {
            await SecureStorage.Default.SetAsync("AppCulture", selectedLang);
            currentLang = selectedLang;

            // Actualizar cultura y forzar recarga completa
            await UpdateCulture(selectedLang);

            // Navegar a la página actual para forzar recarga de todos los componentes
            NavigationManager.NavigateTo("/settings", forceLoad: true);
        }
    }

    private async Task ChangeTheme(ChangeEventArgs e)
    {
        var selectedTheme = e.Value?.ToString() ?? "light";

        if (selectedTheme != currentTheme)
        {
            currentTheme = selectedTheme;
            await SecureStorage.Default.SetAsync("AppTheme", currentTheme);
            await ApplyTheme();
        }
    }

    private async Task ChangeFontSize(ChangeEventArgs e)
    {
        var selectedFontSize = e.Value?.ToString() ?? "default";

        if (selectedFontSize != currentFontSize)
        {
            currentFontSize = selectedFontSize;
            await SecureStorage.Default.SetAsync("AppFontSize", currentFontSize);
            await ApplyFontSize();
        }
    }

    private async Task UpdateCulture(string culture)
    {
        var newCulture = new CultureInfo(culture);
        CultureInfo.CurrentCulture = newCulture;
        CultureInfo.CurrentUICulture = newCulture;
        CultureInfo.DefaultThreadCurrentCulture = newCulture;
        CultureInfo.DefaultThreadCurrentUICulture = newCulture;
    }

    private async Task ApplyTheme()
    {
        try
        {
            // Remove all classes of the primary theme
            await JSRuntime.InvokeVoidAsync("eval",
                "document.body.classList.remove('dark-mode', 'light-mode', 'protanopia-mode', 'deuteranopia-mode', 'tritanopia-mode')");

            // Apply selected theme
            await JSRuntime.InvokeVoidAsync("eval",
                $"document.body.classList.add('{currentTheme}-mode')");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error aplicando tema: {ex.Message}");
        }
    }


    private async Task ApplyFontSize()
    {
        try
        {
            // Usar tu función JavaScript personalizada que modifica la variable CSS
            await JSRuntime.InvokeVoidAsync("applyFontSize", currentFontSize);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error applying font size: {ex.Message}");
        }
    }
}