@page "/settings"
@using AppForSEII2526.Maui.Resources.Languages
@inject IStringLocalizer<Shared> Localizer
@using System.Globalization
@inject NavigationManager NavigationManager

<div class="settings-container">
    <h2>@Localizer["Settings"]</h2>
    
    <div class="setting-group">
        <h3>@Localizer["Language"]</h3>
        <select @onchange="ChangeLanguage" class="lang-select" value="@currentLang">
            <option value="en">English</option>
            <option value="es">Español</option>
            <option value="fr">Français</option>
        </select>
        <p class="setting-description">@Localizer["LanguageDescription"]</p>
    </div>

    <!-- Puedes agregar más configuraciones aquí -->
</div>

@code {
    private string currentLang = "en";

    protected override async Task OnInitializedAsync()
    {
        var saved = await SecureStorage.Default.GetAsync("AppCulture");
        currentLang = saved ?? "en";
        StateHasChanged();
    }

    private async Task ChangeLanguage(ChangeEventArgs e)
    {
        var selectedLang = e.Value?.ToString() ?? "en";

        if (selectedLang != currentLang && (selectedLang == "en" || selectedLang == "es" || selectedLang == "fr"))
        {
            try
            {
                await SecureStorage.Default.SetAsync("AppCulture", selectedLang);
                currentLang = selectedLang;
                
                // Recargar para aplicar cambios
                NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error cambiando idioma: {ex.Message}");
            }
        }
    }
}