@inherits LayoutComponentBase
@using AppForSEII2526.Maui.Resources.Languages
@inject IStringLocalizer<Shared> Localizer
@using System.Globalization
@inject NavigationManager NavigationManager

<!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="header">
    <div class="header-left">
        <img src="/images/logo.png" class="logo" alt="Exergymise Logo" />
        <div class="header-text">
            <h1>EXERGYMISE</h1>
            <p>@Localizer["YourCompleteGymManagementSystem"]</p>
        </div>
    </div>

    <div class="header-right">

        <button class="assistant-icon" title="@Localizer["Assistant"]" @onclick="OpenAssistant">
            <i class="fas fa-robot"></i>
        </button>

        <a href="settings" class="settings-icon" title="@Localizer["Settings"]">
            <i class="fas fa-cog"></i>
        </a>

    </div>
</div>

<div class="menu-container">
    <NavLink href="createplan" class="menu-box" activeClass="menu-box-active">
        <i class="fas fa-dumbbell me-2"></i> @Localizer["CreatePlan"]
    </NavLink>
    <NavLink href="reportincident" class="menu-box" activeClass="menu-box-active">
        <i class="fas fa-exclamation-triangle me-2"></i> @Localizer["ReportIncident"]
    </NavLink>
    <NavLink href="shop" class="menu-box" activeClass="menu-box-active">
        <i class="fas fa-shopping-cart me-2"></i> @Localizer["Shop"]
    </NavLink>
</div>

<main>
    @Body
</main>

@if (showAssistant)
{
    <div class="assistant-panel" id="assistantPanel">
        <button class="assistant-close-btn" id="assistantCloseBtn" @onclick="CloseAssistant">×</button>
        <h3>Assistant</h3>
        <div class="chat-window">
            @foreach (var msg in messages)
            {
                <div class="chat-message">@msg</div>
            }
        </div>
        <input @bind="userInput" placeholder="@Localizer["AssistantPlaceholder"]" />
        <button @onclick="SendMessage">@Localizer["AssistantSend"]</button>
    </div>
}


@code {
    private string currentLang = "en";
    private Timer refreshTimer;

    private bool showAssistant = false;
    private List<string> messages = new();
    private string userInput;

    // Diccionario de palabras clave y claves de resx para la ayuda
    // Diccionario de palabras clave y claves de resx para la ayuda (multilenguaje)
    private Dictionary<string[], string> intentKeywords = new()
    {
        // Saludos
        { new string[]{"hola","hi","hello","bonjour","こんにちは","hey","hey there","salut","buenos días","good morning"}, "AssistantGreeting" },

        // Listar clases disponibles
        { new string[]{"clases","classes","available","disponibles","cours","cours disponibles","クラス","qué clases hay","which classes are available","liste des cours"}, "AssistantListClasses" },

        // Filtrar por tipo de clase
        { new string[]{"yoga","strength","fuerza","force","ヨガ","筋力","pilates","cardio","aeróbico","aerobic","musculación","weight training"}, "AssistantFilterType" },

        // Filtrar por día
        { new string[]{"lunes","monday","martes","tuesday","lundi","mardi","miércoles","wednesday","jueves","thursday","金曜日","viernes","friday","土曜日","sábado","saturday"}, "AssistantFilterDay" },

        // Mostrar precio total
        { new string[]{"precio","total price","costo","coste","prix total","合計金額","cuánto cuesta","how much","total cost","total amount"}, "AssistantTotalPrice" },

        // Crear plan
        { new string[]{"crear plan","create plan","create my plan","crear mi plan","creo mi plan","créer plan","プラン作成","make my plan","build plan","generar plan"}, "AssistantCreatePlan" },

        // Eliminar clase
        { new string[]{"eliminar clase","remove class","quitar clase", "elimino una clase", "quito una clase","supprimer cours","クラス削除","borra clase","delete class","eliminar curso","supprimer cours individuel"}, "AssistantRemoveClass" },

        // Aplicar filtros
        { new string[]{"aplicar filtros","apply filters","aplico filtros","aplico un filtro","appliquer filtres","フィルター適用","filtrar","filter results","set filters"}, "AssistantApplyFilters" },

        // Limpiar filtros
        { new string[]{"limpiar filtros","clear filters","limpio filtros","quito un filtro","quito filtros","effacer filtres","フィルタークリア","reset filters","remove filters","clear all filters"}, "AssistantClearFilters" },

        // Ayuda
        { new string[]{"ayuda","help","ayúdame","aide","ヘルプ","support","assist me","necesito ayuda","assistance"}, "AssistantHelp" },

        // Tienda
        { new string[]{"tienda","shop","comprar","buy", "compro", "acheter","ショップ","ver tienda","go shopping","browse shop","explorar tienda"}, "AssistantShop" }
    };


    protected override async Task OnInitializedAsync()
    {
        var saved = await SecureStorage.Default.GetAsync("AppCulture");
        currentLang = saved ?? "en";

        refreshTimer = new Timer(async _ =>
        {
            await CheckForLanguageChange();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(2));
    }

    private async Task CheckForLanguageChange()
    {
        var saved = await SecureStorage.Default.GetAsync("AppCulture");
        var newLang = saved ?? "en";

        if (newLang != currentLang)
        {
            currentLang = newLang;
            Console.WriteLine($"🔄 Idioma cambiado a: {currentLang}");
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        refreshTimer?.Dispose();
    }

    private void OpenAssistant()
    {
        showAssistant = !showAssistant;
    }

    private void SendMessage()
    {
        if (!string.IsNullOrWhiteSpace(userInput))
        {
            messages.Add($"{Localizer["You"]}: {userInput}");
            string response = GetAssistantResponse(userInput);
            messages.Add($"{Localizer["Assistant"]}: {response}");
            userInput = "";
        }
    }


    private string GetAssistantResponse(string input)
    {
        input = input.ToLower();

        foreach (var pair in intentKeywords)
        {
            foreach (var keyword in pair.Key)
            {
                if (input.Contains(keyword))
                {
                    return Localizer[pair.Value];
                }
            }
        }

        return Localizer["AssistantUnknown"];
    }

    private void CloseAssistant()
    {
        showAssistant = false;
    }

}
