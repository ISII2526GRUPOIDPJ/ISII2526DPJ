@inherits LayoutComponentBase

<div class="page">
    <!-- Sidebar con recuadro naranja importante -->
    <div class="sidebar square-important">
        <NavMenu />
    </div>

    <main>
        <!-- Top row con recuadro secundario -->
        <div class="top-row square-secondary px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank" class="text-dark">About</a>
        </div>

        <!-- Área de contenido principal con recuadro blanco -->
        <article class="content square-important px-4">
            @Body
        </article>
    </main>
</div>