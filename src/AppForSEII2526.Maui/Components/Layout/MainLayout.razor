@inherits LayoutComponentBase
@using AppForSEII2526.Maui.Resources.Languages
@inject IStringLocalizer<Shared> Localizer
@using System.Globalization
@inject NavigationManager NavigationManager

<div class="header">
    <div class="header-left">
        <img src="images/logo.png" class="logo" alt="Exergymise Logo" />
        <div class="header-text">
            <h1>EXERGYMISE</h1>
            <p>@Localizer["YourCompleteGymManagementSystem"]</p>
        </div>
    </div>

    <div class="header-right">
        <select @onchange="ChangeLanguage" class="lang-select" value="@currentLang">
            <option value="en">EN</option>
            <option value="es">ES</option>
        </select>
        <button class="logout-btn">@Localizer["LogOut"]</button>
    </div>
</div>

<div class="menu-container">
    <NavLink href="createplan" class="menu-box" activeClass="menu-box-active">@Localizer["CreatePlan"]</NavLink>
    <NavLink href="reportincident" class="menu-box" activeClass="menu-box-active">@Localizer["ReportIncident"]</NavLink>
    <NavLink href="shop" class="menu-box" activeClass="menu-box-active">@Localizer["Shop"]</NavLink>
</div>

<main>
    @Body
</main>

@code {
    private string currentLang = "en";

    protected override async Task OnInitializedAsync()
    {
        // Recuperar el idioma guardado
        var saved = await SecureStorage.Default.GetAsync("AppCulture");
        currentLang = saved ?? "en";

        // Forzar actualización del estado
        StateHasChanged();
    }

    private async Task ChangeLanguage(ChangeEventArgs e)
    {
        var selectedLang = e.Value?.ToString() ?? "en";

        if (selectedLang != currentLang && (selectedLang == "en" || selectedLang == "es"))
        {
            try
            {
                // Guardar preferencia
                await SecureStorage.Default.SetAsync("AppCulture", selectedLang);
                currentLang = selectedLang;

                // Recargar para aplicar cambios
                NavigationManager.NavigateTo(NavigationManager.Uri, forceLoad: true);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error cambiando idioma: {ex.Message}");
            }
        }
    }
}