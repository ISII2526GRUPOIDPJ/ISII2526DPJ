@inherits LayoutComponentBase
@using AppForSEII2526.Maui.Resources.Languages
@inject IStringLocalizer<Shared> Localizer
@using System.Globalization
@inject NavigationManager NavigationManager

<!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="header">
    <div class="header-left">
        <img src="/images/logo.png" class="logo" alt="Exergymise Logo" />
        <div class="header-text">
            <h1>EXERGYMISE</h1>
            <p>@Localizer["YourCompleteGymManagementSystem"]</p>
        </div>
    </div>

    <div class="header-right">
        <a href="settings" class="settings-icon" title="@Localizer["Settings"]">
            <i class="fas fa-cog"></i>
        </a>

        <a href="#" class="assistant-icon" title="Assistant" @onclick="OpenAssistant">
            <i class="fas fa-robot"></i>
        </a>
    </div>
</div>

<div class="menu-container">
    <NavLink href="createplan" class="menu-box" activeClass="menu-box-active">
        <i class="fas fa-dumbbell me-2"></i> @Localizer["CreatePlan"]
    </NavLink>
    <NavLink href="reportincident" class="menu-box" activeClass="menu-box-active">
        <i class="fas fa-exclamation-triangle me-2"></i> @Localizer["ReportIncident"]
    </NavLink>
    <NavLink href="shop" class="menu-box" activeClass="menu-box-active">
        <i class="fas fa-shopping-cart me-2"></i> @Localizer["Shop"]
    </NavLink>
</div>

<main>
    @Body
</main>

@if (showAssistant)
{
    <div class="assistant-panel">
        <h3>Assistant</h3>
        <div class="chat-window">
            @foreach (var msg in messages)
            {
                <div class="chat-message">@msg</div>
            }
        </div>
        <input @bind="userInput" placeholder="Escribe algo..." />
        <button @onclick="SendMessage">Enviar</button>
    </div>
}

@code {
    private string currentLang = "en";
    private Timer refreshTimer;

    private bool showAssistant = false;
    private List<string> messages = new();
    private string userInput;

    // Diccionario de palabras clave y claves de resx para la ayuda
    private Dictionary<string[], string> intentKeywords = new()
    {
        { new string[]{"hola","hi"}, "AssistantGreeting" },
        { new string[]{"clases","classes","available"}, "AssistantListClasses" },
        { new string[]{"yoga","strength"}, "AssistantFilterType" },
        { new string[]{"lunes","monday","martes","tuesday"}, "AssistantFilterDay" },
        { new string[]{"precio","total price"}, "AssistantTotalPrice" },
        { new string[]{"crear plan","create plan"}, "AssistantCreatePlan" },
        { new string[]{"eliminar clase","remove class"}, "AssistantRemoveClass" },
        { new string[]{"aplicar filtros","apply filters"}, "AssistantApplyFilters" },
        { new string[]{"limpiar filtros","clear filters"}, "AssistantClearFilters" },
        { new string[]{"ayuda","help"}, "AssistantHelp" }
    };

    protected override async Task OnInitializedAsync()
    {
        var saved = await SecureStorage.Default.GetAsync("AppCulture");
        currentLang = saved ?? "en";

        refreshTimer = new Timer(async _ =>
        {
            await CheckForLanguageChange();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(2));
    }

    private async Task CheckForLanguageChange()
    {
        var saved = await SecureStorage.Default.GetAsync("AppCulture");
        var newLang = saved ?? "en";

        if (newLang != currentLang)
        {
            currentLang = newLang;
            Console.WriteLine($"🔄 Idioma cambiado a: {currentLang}");
            await InvokeAsync(StateHasChanged);
        }
    }

    public void Dispose()
    {
        refreshTimer?.Dispose();
    }

    private void OpenAssistant()
    {
        showAssistant = !showAssistant;
    }

    private void SendMessage()
    {
        if (!string.IsNullOrWhiteSpace(userInput))
        {
            messages.Add("Tú: " + userInput);
            string response = GetAssistantResponse(userInput);
            messages.Add("Assistant: " + response);
            userInput = "";
        }
    }

    private string GetAssistantResponse(string input)
    {
        input = input.ToLower();

        foreach (var pair in intentKeywords)
        {
            foreach (var keyword in pair.Key)
            {
                if (input.Contains(keyword))
                {
                    return Localizer[pair.Value];
                }
            }
        }

        return Localizer["AssistantUnknown"];
    }
}
