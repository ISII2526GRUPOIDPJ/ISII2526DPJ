@page "/plan/selectclassesforplan"

@using AppForSEII2526.Web.API;
@inject AppForSEII2526APIClient apiClient
@inject ILogger<SelectClassesForPlan> logger
@inject PlanStateContainer planState


<h3>Select Classes For Plan</h3>
<div class="container-fluid">
    <div class="row" hidden="@hideErrors">
        <p>Errors: @errors</p>
    </div>
    <div class="row">
        <div class="col-8">
            <div class="row">
                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text" id="basic-addon1">Type</span>
                        <input type="text" id="inputType" @bind="type" class="form-control" placeholder="Type" aria-label="Type" aria-describedby="basic-addon1">
                    </div>
                </div>

                <div class="col">
                    <div class="input-group mb-3">
                        <span class="input-group-text">Date</span>
                        <InputDate @bind-Value="@selectedDate" id="selectedDate" />
                    </div>
                </div>

                <div class="col">
                    <button type="button" class="btn btn-primary" @onclick="@SearchPlanning" id="searchPlan">Search plan</button>
                </div>
            </div>
            <div class="row">
                @if (classes == null)
                {
                    <p>Loading classes...</p>
                }
                else if (classes.Count == 0)
                {
                    <p>No classes found for the selected criteria.</p>
                }
                else
                {
                   <div class="mh-100 table-responsive">
                       <table class="table table-condensed table-hover">

                           <thead>
                               <tr>
                                    <th>Name</th>
                                    <th>Type</th>
                                    <th>Date</th>
                                    <th>Price</th>
                                    <th>Add to Plan</th>
                               </tr>
                           </thead>

                           <tbody>
                                @foreach (var classItem in classes)
                                {
                                    <tr id="ClassData_@classItem.Name">
                                        <td>@classItem.Name</td>
                                        <td>@string.Join(", ", classItem.TypeItemNames)</td>
                                        <td>@classItem.DateTime.ToString()</td>
                                        <td>@classItem.Price</td>
                                        <td>
                                            <button class="btn btn-outline-secondary" id="classToAdd_@classItem.Name" @onclick="@(() => AddClassToPlan(classItem))">Add</button>
                                        </td>
                                    </tr>
                                }
                           </tbody>
                       </table>
                   </div>
                }
            </div>
        </div>
        <div class="col-2">
            <p>Here I will show the planning list</p>
        </div>
    </div>
</div>

@code {
    private ICollection<ClassForPlanDTO> classes;

    private bool hideErrors { get { return errors.Length == 0; } }
    private string errors = "";

    private string type { get; set; }

    // Provide a way to filter by a specific date
    private DateTime? selectedDate { get; set; }

    private CreatePlanDTO plan => planState.Plan;

    public async void SearchPlanning()
    {
        try
        {
            string[] typesArray = null;
            if (!string.IsNullOrEmpty(type))
            {
                typesArray = new string[] { type };
            }

            classes = await apiClient.GetClassesForPlanningAsync(selectedDate, typesArray);
            errors = "";
        }
        catch (ApiException ex) when (ex.StatusCode == 404)
        {
            // When no classes are found, we treat 404 as an empty list
            classes = new List<ClassForPlanDTO>();
            errors = "";
            logger.LogInformation($"{DateTime.Now} No classes found for the selected criteria");
        }
        catch (Exception ex)
        {
            logger.LogError($"{DateTime.Now} Error: {ex}");
            errors = "Error while connecting to the system";
        }
        StateHasChanged();
    }

    protected override Task OnInitializedAsync()
    {
        SearchPlanning();
        return base.OnInitializedAsync();
    }

    private void AddClassToPlan(ClassForPlanDTO classItem)
    {
        var classInPlan = new ClassInPlanDTO
        {
            Id = classItem.Id,
            Name = classItem.Name,
            Price = classItem.Price,
            Date = classItem.DateTime,
            TypeItemNames = classItem.TypeItemNames
        };

        planState.AddClassToPlan(classInPlan);
    }

}