    */

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Load types first
            allTypesNames = await apiClient.GetAllClassTypesAsync();
        }
        catch (ApiException ex)
        {
            if (allTypesNames == null)
            {
                allTypesNames = new List<string>();
            }
            logger.LogError("Error! There was an error while connecting to the GetAllClassTypesAsync service");
        }

        // Perform the initial search
        SearchPlanning();
        await base.OnInitializedAsync();
    }

    private void AddClassToPlan(ClassForPlanDTO classItem)
    {
        var classInPlan = new ClassInPlanDTO
        {
            Id = classItem.Id,
            Name = classItem.Name,
            Price = classItem.Price,
            Date = classItem.DateTime,
            TypeItemNames = classItem.TypeItemNames
        };

        planState.AddClassToPlan(classInPlan);
    }

    private void RemoveClassFromPlan(ClassInPlanDTO classItem)
    {
        planState.RemoveClassFromPlan(classItem);
    }

    private void GoToCreatePlan()
    {
        navigation.NavigateTo("/plan/createplan");
    }
}